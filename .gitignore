# macOS
.DS_Store

# バックアップ (Git履歴で代替)
*.bak
bak/

# エディタ作業ファイル
*.swp
*~

# わざリライト作業フォルダ (公開不要)
rewrite_workspace/

# ブランディング作業ファイル (公開素材は characters/, logo/ のみ)
branding/logo_drafts/
branding/preview.html
branding/fonts/

# シークレット (Cloudflare バックアップコード等)
_secrets/

# 検討資料 (内部用、公開不要)
_review/

# セッション間連絡用 (内部用)
shared/

# i18n 作業用ファイル (公開不要 — runtime.js と *.json のみ公開する)
__pycache__/
*.pyc
i18n/cache/
i18n/bak/
i18n/*.py
i18n/*.log
i18n/preview*.html
i18n/hreflang_blocks_strategy_*.html
i18n/sitemap_strategy_*.xml

# pokechan_data.js のバックアップ群 (公開不要・git 履歴で代替)
pokechan_data.js.bak*

# Claude Code ローカル設定・agent worktree (ローカル専用)
.claude/
